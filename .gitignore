# Built application files
*.apk
*.aab
*.ap_
*.aar
*.dex

# Java/Kotlin compiled classes
*.class

# Log files
*.log
hs_err_pid*
replay_pid*

# Gradle
.gradle/
build/
.kotlin/

# Local configuration file (SDK path etc.) — machine-specific
local.properties

# Android Studio / IntelliJ project files
*.iml
.idea/

# Native build artifacts
.cxx/
.externalNativeBuild/

# Instrumentation / profiler captures
captures/

# Signing keys — never commit real (Play Store) release keystores.
# Исключение: app/keystore/release.jks — это намеренно закоммиченный общий
# "коммьюнити" ключ для сборок из GitHub Releases, не для публикации в Play.
*.jks
*.keystore
!app/keystore/release.jks

# macOS
.DS_Store
